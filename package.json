{
  "name": "model-prompt-forge",
  "version": "1.0.0",
  "type": "module",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "test": "node --test",
    "test:character-sheet": "node scripts/test-character-sheet-release-gate.js",
    "test:prompt-cleanup": "node scripts/test-prompt-cleanup.js",
    "i18n:sync-vendor": "node scripts/sync-i18next-browser-assets.js",
    "i18n:validate": "node scripts/validate-i18n-catalogs.js",
    "migrate:thumbnails": "node scripts/migrate-history-thumbnails.js",
    "visual-assets:check": "node scripts/slice-visual-assets.js --check",
    "visual-assets:check:character-sheet": "node scripts/slice-visual-assets.js --check --field=character-sheet",
    "visual-assets:slice": "node scripts/slice-visual-assets.js --slice",
    "visual-assets:slice:character-sheet": "node scripts/slice-visual-assets.js --slice --field=character-sheet",
    "visual-assets:contact-sheet": "node scripts/slice-visual-assets.js --contact-sheet"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "i18next": "^26.3.6",
    "i18next-http-backend": "^4.0.0",
    "nodemon": "^3.1.14",
    "openai": "^6.46.0",
    "sharp": "^0.34.3"
  }
}
