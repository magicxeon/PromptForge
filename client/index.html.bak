<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ModelPromptForge - Premium AI Prompt Generator</title>
  <!-- Google Fonts: Outfit for Headers, Inter for Body -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <div class="app-container">
    <!-- Header -->
    <header class="app-header">
      <div class="header-main-row" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; margin-bottom: 0.5rem;">
        <div class="logo-area">
          <h1>ModelPromptForge</h1>
          <span class="badge neon-glow-pink">Asian Aesthetic v1.0</span>
        </div>
        
        <!-- Role & Credit controls -->
        <div class="role-credits-container" style="display: flex; align-items: center; gap: 1rem; background: rgba(255, 255, 255, 0.05); padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.1);">
          <div class="role-selector" style="display: flex; align-items: center; gap: 0.5rem;">
            <label for="role-select" style="font-size: 0.85rem; font-weight: 600; color: var(--text-muted);">Account:</label>
            <select id="role-select" style="padding: 0.25rem 0.5rem; background: var(--bg-color); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 4px; color: var(--text-main); font-size: 0.85rem; outline: none; cursor: pointer;">
              <option value="user_demo">user_demo (User)</option>
              <option value="admin_demo">admin_demo (Admin)</option>
            </select>
          </div>
          <div class="credits-display" style="font-size: 0.9rem; font-weight: 700; color: #fbbf24; display: flex; align-items: center; gap: 0.25rem;">
            <span>Credits:</span> <span id="credits-value">20</span> 🪙
          </div>
        </div>
      </div>
      <p class="subtitle">Generate high-fidelity, photorealistic prompts from structured attributes safely without policy violations.</p>
    </header>

    <!-- Main Workspace -->
    <main class="app-workspace">
      <!-- Left Panel: Dynamic Form Builder -->
      <section class="form-panel glass-card">
        <div class="panel-header">
          <h2>Attribute Selector</h2>
          <span class="sub-label">Select settings below to construct your prompt</span>
        </div>

        <!-- Generation Mode Selector -->
        <div class="mode-selector-section">
          <label>Generation Mode</label>
          <div class="mode-chip-group">
            <button class="mode-chip active" data-mode="normal">Normal</button>
            <button class="mode-chip" data-mode="headshot">Headshot</button>
            <button class="mode-chip" data-mode="character-sheet">Character Sheet</button>
          </div>

          <!-- Reference Image Checkbox (only visible in character-sheet mode) -->
          <div id="image-upload-container" class="mode-sub-control" style="display: none;">
            <div class="checkbox-group">
              <label class="checkbox-container">
                <input type="checkbox" id="sheet-use-reference-img">
                <span class="checkmark"></span>
                <span class="label-text">ทำภาพต้นแบบจากรูปที่อัพโหลดขึ้นไป (Generate from uploaded reference)</span>
              </label>
            </div>
          </div>
        </div>

        <div id="form-container" class="accordions-container">
          <!-- Dynamically loaded inputs will be rendered here by app.js -->
          <div class="loading-placeholder">
            <div class="spinner"></div>
            <p>Loading attribute schemas...</p>
          </div>
        </div>
      </section>

      <!-- Right Panel: Sticky Preview & Output Controls -->
      <section class="control-panel glass-card">
        <!-- Aesthetic Presets -->
        <div class="control-section">
          <h3>Aesthetic Presets</h3>
          <p class="section-desc">Quick load curated presets to start with:</p>
          <div class="chip-group" id="presets-group">
            <button class="option-chip" data-preset="nightclub">Nightclub Aura Red</button>
            <button class="option-chip" data-preset="studio">Studio Porcelain</button>
            <button class="option-chip" data-preset="street">Street Dewy Waves</button>
            <button class="option-chip" data-preset="thaiSilk">Thai Silk Elegance</button>
            <button class="option-chip" data-preset="cheongsam">Cheongsam Vintage</button>
            <button class="option-chip" data-preset="minimalistCafe">Minimalist Cafe</button>
            <button class="option-chip" data-preset="beachCasual">Sunny Beach Casual</button>
            <button class="option-chip" data-preset="restaurantSitting">Rooftop Restaurant</button>
            <button class="option-chip" data-preset="barSitting">Vibrant Bar</button>
            <button class="option-chip" data-preset="resortSitting">Luxury Resort</button>
            <button class="option-chip" data-preset="naturePhoto">Nature Forest</button>
            <button class="option-chip" data-preset="mallWaiting">Shopping Mall</button>
          </div>
        </div>

        <!-- Template Selection -->
        <div class="control-section">
          <h3>Prompt Template</h3>
          <div class="select-wrapper">
            <select id="template-select" class="custom-select">
              <!-- Templates loaded dynamically -->
            </select>
          </div>
        </div>

        <!-- Aspect Ratio Selection -->
        <div class="control-section">
          <h3>Aspect Ratio</h3>
          <div class="chip-group" id="aspect-ratio-group">
            <button class="option-chip active" data-ratio="6:8">(6:8) Portrait Default</button>
            <button class="option-chip" data-ratio="1:1">(1:1) Square</button>
            <button class="option-chip" data-ratio="9:16">(9:16) Mobile Portrait</button>
            <button class="option-chip" data-ratio="16:9">(16:9) Widescreen</button>
            <button class="option-chip" data-ratio="4:5">(4:5) Instagram</button>
          </div>
        </div>

        <!-- Image Reference Attributes (No Actual Upload) -->
        <div class="control-section">
          <h3>Image Reference Options</h3>
          <p class="section-desc">Refer to external source files in the prompt without uploading them.</p>
          <div class="checkbox-group">
            <label class="checkbox-container">
              <input type="checkbox" id="ref-face-match">
              <span class="checkmark"></span>
              <span class="label-text">Face Match (100% Identity Lock)</span>
            </label>
            <label class="checkbox-container">
              <input type="checkbox" id="ref-style-match">
              <span class="checkmark"></span>
              <span class="label-text">Style & Outfit Match</span>
            </label>
            <label class="checkbox-container">
              <input type="checkbox" id="ref-pose-match">
              <span class="checkmark"></span>
              <span class="label-text">Pose & Composition Match</span>
            </label>
          </div>
        </div>

        <!-- Content Settings -->
        <div class="control-section">
          <h3>Content Settings</h3>
          <div class="checkbox-group">
            <label class="checkbox-container">
              <input type="checkbox" id="toggle-nsfw">
              <span class="checkmark"></span>
              <span class="label-text">Enable NSFW Options</span>
            </label>
            <label class="checkbox-container">
              <input type="checkbox" id="toggle-gpt-safe">
              <span class="checkmark"></span>
              <span class="label-text">GPT-Safe Mode (Avoid Violations)</span>
            </label>
          </div>
        </div>

        <!-- Real-Time Compiled Preview -->
        <div class="control-section preview-section">
          <div class="preview-header">
            <h3>Live Prompt Preview</h3>
            <div style="display: flex; gap: 0.5rem;">
              <button id="btn-copy" class="btn-neon-action">Copy Text</button>
              <button id="btn-copy-json" class="btn-neon-action">Copy JSON</button>
            </div>
          </div>
          <div id="prompt-preview" class="prompt-preview-box">
            <!-- Assembled prompt segments colored dynamically -->
            <span class="placeholder-text">Prompt will generate here once attributes are selected...</span>
          </div>
          <div id="buzzword-warnings" class="buzzword-warnings-box" style="display: none;">
            <!-- Render warnings dynamically -->
          </div>
        </div>

        <!-- API Generation Section -->
        <div class="control-section api-generation-section" style="border-top: 1px solid rgba(255, 255, 255, 0.08); padding-top: 1.25rem; margin-top: 0.5rem;">
          <h3>Generate Image via API</h3>
          <div style="display: flex; gap: 0.75rem; margin-bottom: 0.75rem; align-items: center;">
            <div class="select-wrapper" style="flex: 1;">
              <select id="api-provider-select" class="custom-select">
                <option value="gemini">Google Gemini (Imagen 3)</option>
                <option value="openai">OpenAI (DALL-E 3)</option>
              </select>
            </div>
            <button id="btn-generate-image" class="btn-neon" style="flex: 1; padding: 0.65rem;">⚡ Generate Image</button>
          </div>
          
          <!-- Image Output Container -->
          <div id="image-output-container" class="image-output-box" style="display: none; background: rgba(0, 0, 0, 0.2); border: 1px dashed rgba(255, 255, 255, 0.1); border-radius: 8px; padding: 0.5rem; text-align: center; position: relative; min-height: 200px;">
            <div class="image-loading-overlay" id="image-loading-overlay" style="display: none; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); align-items: center; justify-content: center; border-radius: 8px;">
              <div class="spinner"></div>
            </div>
            <img id="generated-image" src="" alt="Generated Character" style="max-width: 100%; max-height: 400px; border-radius: 6px; object-fit: contain; box-shadow: 0 4px 20px rgba(0,0,0,0.5);">
          </div>
        </div>

        <!-- Main Action Buttons -->
        <div class="action-grid">
          <button id="btn-reset" class="btn-neon-outline">Reset</button>
          <button id="btn-random" class="btn-neon-cyan">🎲 Surprise Me</button>
          <button id="btn-export" class="btn-neon">Export Preset</button>
        </div>

        <!-- Import Config Section -->
        <div class="control-section import-section">
          <label class="file-upload-label">
            <input type="file" id="btn-import" accept=".json" style="display: none;">
            <span>Upload JSON Preset to Restore Settings</span>
          </label>
        </div>
      </section>
    </main>
  </div>

  <script src="app.js"></script>
</body>
</html>
