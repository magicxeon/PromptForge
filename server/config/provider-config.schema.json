{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schemaVersion", "defaultProvider", "providers"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "defaultProvider": { "type": "string", "minLength": 1 },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "adapter", "enabled", "displayName", "apiKeyEnv", "defaultModel", "models"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "adapter": { "type": "string", "minLength": 1 },
          "enabled": { "type": "boolean" },
          "displayName": { "type": "object" },
          "apiKeyEnv": { "type": "string", "minLength": 1 },
          "apiKeyEnvAliases": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "baseUrlEnv": { "type": "string", "minLength": 1 },
          "defaultModel": { "type": "string", "minLength": 1 },
          "models": { "type": "array", "minItems": 1 }
        }
      }
    }
  }
}
