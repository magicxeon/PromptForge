PORT=6500
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
CIVITAI_API_KEY=
# xAI Grok Imagine image generation and edit API key.
X_API_KEY=your_xai_api_key_here
MODEL_ARK_API-KEY=your_ark_api_key_here
# Optional aliases for deployments that cannot use hyphenated env names.
MODEL_ARK_API=
ARK_API_KEY=
MODEL_ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
MODEL_ARK_API_TIMEOUT_MS=180000
XAI_API_TIMEOUT_MS=120000
PROVIDER_CONFIG_PATH=server/config/providers.json
MAX_CONCURRENT_GENERATIONS=2
# Set to false to use the standard OpenAI image response without partial-image streaming.
# If omitted, streaming remains enabled for backward compatibility.
ENABLE_OPENAI_API_STREAMING=false
ENABLED_CACHE_ATTRIBUTE_BUNDLE=false
REFRESH_CACHE_ATTRIBUTE_BUNDLE=true
